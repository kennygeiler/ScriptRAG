ANTHROPIC_API_KEY=

# Neo4j
# Local: neo4j://localhost:7687 or bolt://localhost:7687
# Neo4j Aura: use the URI from the console (often neo4j+s://xxxx.databases.neo4j.io)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
# For docker-compose.stack.yml, set a strong password (used for Neo4j + app).
NEO4J_PASSWORD=

# LangSmith telemetry (loaded by etl_core/config.py). Optional for trace UI in LangSmith.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=scriptrag

# Set to 1 for read-only deployments — hides Pipeline tab (no extraction, view-only dashboard).
# DISABLE_PIPELINE=1

# Optional: directory for durable app files (pipeline efficiency log). On Render, set to /var/data with a persistent disk.
# Local docker-compose sets this to /var/data with a named volume.
# PERSISTENT_DATA_DIR=/var/data
